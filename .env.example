# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Public (exposed to browser via VITE_ prefix) ───────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# ─── RunPod (Qwen3-Embedding-4B serverless) ─────────────
RUNPOD_API_KEY=...
RUNPOD_ENDPOINT_ID=...

# ─── Optional: email notifications ──────────────────────
# RESEND_API_KEY=re_...
# NOTIFICATION_EMAIL=you@example.com

# ─── Optional: n8n webhook trigger on submit ────────────
# N8N_WEBHOOK_URL=https://your-public-n8n-url/webhook/quiz-submit
# N8N_WEBHOOK_SECRET=your-shared-secret
